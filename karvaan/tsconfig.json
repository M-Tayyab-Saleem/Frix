{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "App.tsx",
    "src/api/**/*",
    "src/components/**/*",
    "src/constants/**/*",
    "src/lib/**/*",
    "src/navigation/**/*",
    "src/screens/**/*",
    "src/services/**/*",
    "src/store/**/*",
    "src/types/**/*",
    "src/utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/store/__tests__",
    "src/_archive",
    "src/features",
    "src/services/analytics.ts",
    "src/lib/analytics.ts",
    "src/utils/dateFormatter.ts",
    "src/utils/__tests__/**/*",
    "src/store/useAuthStore.ts",
    "src/components/SoftAuthGateModal.tsx"
  ],
  "extends": "expo/tsconfig.base"
}
